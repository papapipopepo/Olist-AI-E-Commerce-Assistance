# ============================================
# Olist AI Assistant — Environment Variables
# ============================================
# Copy ke .env dan isi nilainya

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model config (jangan diubah kecuali perlu)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_PRODUCTS=olist_products
QDRANT_COLLECTION_REVIEWS=olist_reviews

# ── Langfuse (Observability) ──────────────────────────────────────────────────
# Daftar gratis di https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com   # atau self-hosted URL

# ── SQLite ────────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./database/olist.db

# ── App Config ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
